{
  "expo": {
    "name": "SUTMS",
    "slug": "sutms",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "sutms",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.university.sutms"
    },
    "android": {
      "package": "com.university.sutms",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      [
        "expo-camera",
        { "cameraPermission": "Allow SUTMS to access your camera" }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow SUTMS to access your location" }
      ],
      [
        "expo-notifications",
        { "color": "#1A73E8" }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow SUTMS to access your photos" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
